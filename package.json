{
  "name": "programmers-helper",
  "displayName": "Programmers Helper",
  "description": "Solve Programmers coding test problems locally in VS Code",
  "version": "0.0.1",
  "publisher": "godkisng",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "programmers.setSessionCookie",
        "title": "Programmers: Set Session Cookie"
      },
      {
        "command": "programmers.login",
        "title": "Programmers: Login (Auto)"
      },
      {
        "command": "programmers.checkConnection",
        "title": "Programmers: Check Connection"
      },
      {
        "command": "programmers.openProblem",
        "title": "Programmers: Open Problem",
        "icon": "$(add)"
      },
      {
        "command": "programmers.runSampleTests",
        "title": "Programmers: Run Sample Tests",
        "icon": "$(play)"
      },
      {
        "command": "programmers.copySolutionForSubmit",
        "title": "Programmers: Copy Solution for Submission",
        "icon": "$(copy)"
      },
      {
        "command": "programmers.addTestCase",
        "title": "Programmers: Add Test Case",
        "icon": "$(add)"
      },
      {
        "command": "programmers.openProblemById",
        "title": "Programmers: Open Problem by Id"
      },
      {
        "command": "programmers.revealSolution",
        "title": "Programmers: Reveal Solution File"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "programmers",
          "title": "Programmers",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "programmers": [
        {
          "id": "programmersProblems",
          "name": "문제"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "programmersProblems",
        "contents": "아직 연 문제가 없습니다.\n[문제 열기](command:programmers.openProblem)\n로그인이 필요하면 아래를 이용하세요.\n[로그인](command:programmers.login)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "programmers.openProblem",
          "when": "view == programmersProblems",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "programmers.runSampleTests",
          "when": "view == programmersProblems && viewItem == currentProblem",
          "group": "inline@1"
        },
        {
          "command": "programmers.copySolutionForSubmit",
          "when": "view == programmersProblems && viewItem == currentProblem",
          "group": "inline@2"
        }
      ],
      "commandPalette": [
        {
          "command": "programmers.openProblemById",
          "when": "false"
        },
        {
          "command": "programmers.revealSolution",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run typecheck && npm run build",
    "typecheck": "tsc --noEmit",
    "build": "node esbuild.mjs",
    "compile": "tsc -p ./",
    "watch": "node esbuild.mjs --watch",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "playwright-core": "^1.61.1",
    "sanitize-html": "^2.17.5"
  }
}
